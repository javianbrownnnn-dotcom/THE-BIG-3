# Copy to .env.local and fill in to run against a real Supabase backend.
# Leave unset to run the fully seeded demo mode (no backend required).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Edge function secrets (set with `supabase secrets set`, NOT in this file):
#   ANTHROPIC_API_KEY   — Claude API key for the coach / learning loop / reports
#   CLAUDE_MODEL        — optional, defaults to claude-sonnet-5
